# ============================================================
# LLM API 凭据配置
# 复制此文件为 .env 后填入你的 Key
# .env 已在 .gitignore 中，不会提交到版本控制
# ============================================================

# --- OpenAI / 兼容接口 ---
OPENAI_API_KEY=
# 可选：自定义 API 地址（使用代理或兼容接口时）
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Azure OpenAI ---
AZURE_API_KEY=
AZURE_ENDPOINT=https://xxx.openai.azure.com
AZURE_API_VERSION=

# --- DeepSeek / 其他兼容接口 ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Ollama 本地模型 ---
OLLAMA_BASE_URL=http://localhost:11434

# --- 默认使用的 LLM 提供方 ---
LLM_PROVIDER=
